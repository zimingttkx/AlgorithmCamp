# AlgorithmCamp Environment Variables Template
# Copy this file to .env and fill in your production values
# DO NOT commit the actual .env file to version control!

# ===========================================
# Application Settings
# ===========================================

NODE_ENV=production
PORT=3000

# Domain URLs
FRONTEND_URL=https://yourdomain.com
API_URL=https://api.yourdomain.com

# ===========================================
# Database (PostgreSQL)
# ===========================================
# These values must match the docker-compose.yml postgres service

PGHOST=localhost
PGPORT=5432
PGDATABASE=algorithmcamp
PGUSER=postgres
PGPASSWORD=your_secure_postgres_password_here

# Full database URL (alternative to individual PG* vars)
# DATABASE_URL=postgresql://postgres:your_secure_postgres_password_here@localhost:5432/algorithmcamp

# ===========================================
# Authentication
# ===========================================

# JWT Secret (generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))")
JWT_SECRET=generate_a_64_character_random_hex_string_here

# GitHub OAuth (create at: https://github.com/settings/developers)
# Callback URL: https://api.yourdomain.com/api/auth/github/callback
GITHUB_CLIENT_ID=your_github_oauth_app_client_id
GITHUB_CLIENT_SECRET=your_github_oauth_app_client_secret

# ===========================================
# GitHub Integration
# ===========================================

# GitHub Personal Access Token (for fetching commit/stats)
# Needs: repo:status, public_repo scopes
GITHUB_TOKEN=your_github_personal_access_token
GITHUB_USER=zimingttkx

# Enable cron job for GitHub stats updates
CRON_ENABLED=true

# ===========================================
# SSL Certificate (Certbot)
# ===========================================

# Uncomment and set after Certbot has generated certificates
# SSL_CERT_PATH=/etc/letsencrypt/live/yourdomain.com/fullchain.pem
# SSL_KEY_PATH=/etc/letsencrypt/live/yourdomain.com/privkey.pem

# ===========================================
# Server Paths
# ===========================================

# Working directory on the server (should match ecosystem.config.js cwd)
SERVER_WEB_ROOT=/var/www/algorithmcamp
SERVER_APP_DIR=/var/www/algorithmcamp/app
SERVER_SERVER_DIR=/var/www/algorithmcamp/server
