# Environment variables for AlgorithmCamp Server
# Copy this to .env and fill in your values

# Server
PORT=3000
NODE_ENV=production

# JWT Secret (generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))")
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# PostgreSQL Database
PGHOST=localhost
PGPORT=5432
PGDATABASE=algorithmcamp
PGUSER=postgres
PGPASSWORD=your_postgres_password

# GitHub OAuth (for login with GitHub)
# Create OAuth App at: https://github.com/settings/developers
GITHUB_CLIENT_ID=your_github_oauth_client_id
GITHUB_CLIENT_SECRET=your_github_oauth_client_secret
API_URL=http://localhost:3000

# GitHub Personal Access Token (for fetching commit stats)
# Needs: repo:status, public_repo (or full repo access)
# Generate at: https://github.com/settings/tokens
GITHUB_TOKEN=ghp_your_github_token_here

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:5173

# Enable cron job for GitHub stats (set to 'true' in production)
CRON_ENABLED=false
